---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Catalog from '../components/Catalog.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';
---

<Layout 
	title="Catálogo de Repuestos y Componentes Garantizados | SERVITECNOLOGY" 
	description="Encuentra repuestos originales usados y garantizados: pantallas, teclados, almacenamiento, memorias RAM para laptops y PCs de escritorio con opción de instalación en Santiago."
	keywords="repuestos pc, repuestos laptop, pantallas notebook, memoria ram, disco ssd, cargadores, servitecnology"
>
	<!-- Fixed Header -->
	<Header />
	
	<main class="relative bg-black min-h-screen">
		<!-- Parts & Components Catalog -->
		<Catalog />
	</main>

	<!-- Footer -->
	<Footer />

	<!-- Floating WhatsApp CTA -->
	<WhatsAppButton phone="56948672300" message="Hola SERVITECNOLOGY, consulto por repuestos..." />
</Layout>
