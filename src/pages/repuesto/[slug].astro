---
export const prerender = false;

import { supabase } from '../../lib/supabase';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Button from '../../components/Button.astro';

const { slug } = Astro.params;

// Fetch product details (graceful)
let product: any = null;
try {
	const { data } = await supabase
		.from('repuestos_productos')
		.select('*')
		.eq('slug', slug)
		.single();
	product = data;
} catch (e: any) {
	console.error('[repuesto] Supabase error:', e?.message);
}

if (!product) {
	return Astro.redirect('/');
}

const titleSEO = product.seo_titulo || `${product.titulo} | Repuestos SERVITECH`;
const descSEO = product.seo_descripcion || product.descripcion || `Adquiere ${product.titulo} testeado con stock garantizado en SERVITECH.`;
const keywordsSEO = product.seo_keywords || `repuesto, ${product.titulo}, servitech`;

const phone = "56948672300";
const msg = encodeURIComponent(`Hola SERVITECH, me interesa el repuesto: ${product.titulo} (SKU: ${product.sku}) que vi en su catálogo web en la URL de detalle. ¿Tienen stock o valor con instalación?`);
const waLink = `https://wa.me/${phone}?text=${msg}`;

const images: string[] = product.imagenes ?? [];
const hasMultipleImages = images.length > 1;
---

<Layout title={titleSEO} description={descSEO} keywords={keywordsSEO}>
	<Header />
	
	<main class="relative bg-black min-h-screen py-20 border-b border-white/5">
		<!-- Background Glows -->
		<div class="absolute top-1/4 left-1/4 -translate-x-1/2 -translate-y-1/2 w-[300px] md:w-[500px] h-[300px] md:h-[500px] bg-brand-cyan/5 rounded-full blur-[120px] pointer-events-none"></div>
		<div class="absolute bottom-1/4 right-1/4 translate-x-1/2 translate-y-1/2 w-[300px] md:w-[500px] h-[300px] md:h-[500px] bg-brand-green/5 rounded-full blur-[120px] pointer-events-none"></div>

		<div class="relative z-10 mx-auto max-w-5xl px-6 w-full mt-8">
			<!-- Back Button -->
			<a href="/#catalogo" class="inline-flex items-center gap-2 text-xs font-semibold text-slate-400 hover:text-brand-cyan transition-colors mb-8">
				← Volver al catálogo de repuestos
			</a>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-start bg-zinc-950/45 border border-white/5 p-8 rounded-2xl backdrop-blur-sm">
				
				<!-- Product Gallery (Left) -->
				<div>
					{images.length > 0 ? (
						<div class="relative w-full aspect-[4/3] rounded-xl overflow-hidden bg-zinc-900 border border-white/10 shadow-2xl">
							{images.map((img, idx) => (
								<img
									src={img}
									alt={`${product.titulo} - imagen ${idx + 1}`}
									class:list={[
										"detail-carousel-img absolute inset-0 w-full h-full object-cover transition-opacity duration-500",
										idx === 0 ? "opacity-100" : "opacity-0"
									]}
									data-index={idx}
									loading="eager"
								/>
							))}
							{hasMultipleImages && (
								<div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-1.5 z-10">
									{images.map((_, idx) => (
										<button
											data-detail-dot={idx}
											class:list={[
												"w-2.5 h-2.5 rounded-full transition-all duration-300 cursor-pointer",
												idx === 0 ? "bg-brand-cyan scale-125" : "bg-white/40 hover:bg-white/60"
											]}
											aria-label={`Ver imagen ${idx + 1}`}
										/>
									))}
								</div>
							)}
						</div>
					) : (
						<div class="w-full aspect-[4/3] rounded-xl bg-zinc-900 border border-white/5 flex items-center justify-center text-slate-600">
							No hay imagen disponible
						</div>
					)}
				</div>

				<!-- Product Details (Right) -->
				<div class="space-y-6">
					<!-- Badges -->
					<div class="flex flex-wrap gap-2">
						<span class="text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-full border text-brand-cyan bg-brand-cyan/10 border-brand-cyan/20">
							{product.estado || 'Usado Verificado'}
						</span>
						<span class="text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-full border text-slate-400 bg-white/5 border-white/10">
							SKU: {product.sku}
						</span>
						<span class="text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-full border text-brand-green bg-brand-green/10 border-brand-green/20">
							{product.categoria}
						</span>
					</div>

					<h1 class="text-3xl font-extrabold text-white tracking-tight leading-tight">
						{product.titulo}
					</h1>

					<!-- Price -->
					<div class="flex items-baseline gap-2 border-y border-white/5 py-4">
						<span class="text-3xl font-black text-white">${product.precio_venta?.toLocaleString('es-CL')}</span>
						<span class="text-xs text-slate-500 uppercase font-semibold">CLP</span>
					</div>

					<!-- Stock Badge -->
					<div class="flex items-center gap-2">
						{product.stock_cantidad > 0 ? (
							<>
								<span class="w-2.5 h-2.5 rounded-full bg-brand-green animate-pulse shrink-0"></span>
								<span class="text-sm font-semibold text-brand-green">Disponibles: {product.stock_cantidad} unidades</span>
							</>
						) : (
							<>
								<span class="w-2.5 h-2.5 rounded-full bg-red-500 shrink-0"></span>
								<span class="text-sm font-semibold text-red-500">Agotado Temporalmente</span>
							</>
						)}
					</div>

					<!-- Description -->
					<div class="space-y-2">
						<h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider">Descripción del Repuesto</h3>
						<p class="text-sm text-slate-300 leading-relaxed whitespace-pre-line">
							{product.descripcion}
						</p>
					</div>

					<!-- Compatibility -->
					{product.compatibilidad && product.compatibilidad.length > 0 && (
						<div class="space-y-2">
							<h3 class="text-xs font-bold text-slate-400 uppercase tracking-wider">Compatibilidad de Equipos</h3>
							<div class="flex flex-wrap gap-1.5">
								{product.compatibilidad.map((comp: string) => (
									<span class="text-xs px-2.5 py-1 rounded-md bg-white/5 border border-white/5 text-slate-300">
										{comp}
									</span>
								))}
							</div>
						</div>
					)}

					<!-- CTA button -->
					<div class="pt-4">
						<a
							href={product.stock_cantidad > 0 ? waLink : "#"}
							target={product.stock_cantidad > 0 ? "_blank" : "_self"}
							rel="noopener noreferrer"
							data-track-event="clic_boton"
							data-element-id={`btn_whatsapp_producto_${product.sku}`}
							class={`flex items-center justify-center gap-3 w-full px-6 py-4 rounded-xl font-bold tracking-wide transition-all duration-300 ${product.stock_cantidad > 0 ? 'bg-brand-green text-black hover:opacity-90 active:scale-98 shadow-[0_0_30px_rgba(0,255,127,0.2)]' : 'bg-red-500/10 text-red-500 border border-red-500/20 opacity-50 cursor-not-allowed pointer-events-none'}`}
						>
							<svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.746.953 3.71 1.458 5.704 1.459h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
							{product.stock_cantidad > 0 ? "Consultar disponibilidad vía WhatsApp" : "No disponible"}
						</a>
					</div>
				</div>

			</div>
		</div>
	</main>

	<Footer />
</Layout>

<script>
	// Detail Image carousel logic
	document.querySelectorAll('[data-detail-dot]').forEach(dot => {
		dot.addEventListener('click', () => {
			const targetIdx = dot.getAttribute('data-detail-dot')!;
			// Hide all images
			document.querySelectorAll('.detail-carousel-img').forEach(img => {
				(img as HTMLElement).style.opacity = '0';
			});
			// Show target image
			const target = document.querySelector(`.detail-carousel-img[data-index="${targetIdx}"]`) as HTMLElement;
			if (target) target.style.opacity = '1';
			// Update dots
			document.querySelectorAll('[data-detail-dot]').forEach(d => {
				d.classList.remove('bg-brand-cyan', 'scale-125');
				d.classList.add('bg-white/40');
			});
			dot.classList.remove('bg-white/40');
			dot.classList.add('bg-brand-cyan', 'scale-125');
		});
	});
</script>
