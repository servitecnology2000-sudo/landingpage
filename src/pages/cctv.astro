---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';

const serviceTitle = "Seguridad e Instalación de CCTV";
const serviceDescription = "Diseño, montaje e integración de sistemas de videovigilancia IP y análoga de alta definición. Configuración integrada para monitoreo en vivo desde tu smartphone o tablet en Santiago.";
const waMessage = encodeURIComponent(`Hola SERVITECNOLOGY, me interesa cotizar una instalación de cámaras de seguridad CCTV.`);
const waLink = `https://wa.me/56948672300?text=${waMessage}`;
---

<Layout 
	title={`${serviceTitle} | SERVITECNOLOGY`} 
	description={serviceDescription}
	keywords="cctv, camaras de seguridad, instalar camaras, videovigilancia, grabador dvr, camara ip, domotica, santiago"
>
	<Header />

	<main class="relative bg-black min-h-screen pt-24 pb-20 overflow-hidden">
		<!-- Background Glows -->
		<div class="absolute top-1/4 left-1/4 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-brand-cyan/5 rounded-full blur-[140px] pointer-events-none"></div>
		<div class="absolute bottom-1/4 right-1/4 translate-x-1/2 translate-y-1/2 w-[500px] h-[500px] bg-brand-green/5 rounded-full blur-[140px] pointer-events-none"></div>

		<!-- HERO SECTION -->
		<section class="relative z-10 mx-auto max-w-5xl px-6 w-full text-center py-12 md:py-20 space-y-6">
			<div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-brand-cyan/20 bg-brand-cyan/5 text-brand-cyan text-sm font-semibold uppercase tracking-wider">
				Monitoreo & Seguridad
			</div>
			<h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-white leading-tight">
				Sistemas de CCTV <br class="hidden sm:inline" />
				<span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-cyan to-brand-green">
					y Seguridad Inteligente
				</span>
			</h1>
			<p class="text-slate-400 text-lg md:text-xl max-w-3xl mx-auto leading-relaxed">
				{serviceDescription}
			</p>
			<div class="pt-6">
				<a 
					href={waLink}
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex justify-center items-center gap-3 bg-brand-cyan text-black hover:bg-brand-green px-8 py-4 md:py-5 rounded-xl font-bold text-lg transition-all duration-300 shadow-[0_0_20px_rgba(0,207,255,0.2)] hover:scale-105"
				>
					Cotizar Mi Instalación
					<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
				</a>
			</div>
		</section>

		<!-- PROCESO DE CONTRATACIÓN -->
		<section class="relative z-10 mx-auto max-w-5xl px-6 w-full py-16 border-t border-white/5">
			<h2 class="text-2xl md:text-4xl font-extrabold text-white text-center mb-12">
				Proceso de Contratación y <span class="text-brand-cyan">Despliegue</span>
			</h2>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
				<div class="bg-zinc-950/50 border border-white/5 p-6 rounded-2xl relative overflow-hidden group hover:border-brand-cyan/20 transition-all duration-300">
					<div class="absolute -top-4 -right-4 text-8xl font-black text-white/5 select-none">1</div>
					<h3 class="text-xl font-bold text-white mb-3">1. Levantamiento Técnico</h3>
					<p class="text-slate-400 text-sm leading-relaxed">
						Evaluamos tu propiedad (domicilio o local comercial) en terreno o mediante planos para identificar los puntos ciegos y mejores ángulos de visualización.
					</p>
				</div>
				<div class="bg-zinc-950/50 border border-white/5 p-6 rounded-2xl relative overflow-hidden group hover:border-brand-cyan/20 transition-all duration-300">
					<div class="absolute -top-4 -right-4 text-8xl font-black text-white/5 select-none">2</div>
					<h3 class="text-xl font-bold text-white mb-3">2. Diseño y Propuesta</h3>
					<p class="text-slate-400 text-sm leading-relaxed">
						Diseñamos el mapa de cámaras seleccionando los lentes ideales (fijos o varifocales) e infrarrojo adecuado, y te presentamos el presupuesto formal.
					</p>
				</div>
				<div class="bg-zinc-950/50 border border-white/5 p-6 rounded-2xl relative overflow-hidden group hover:border-brand-cyan/20 transition-all duration-300">
					<div class="absolute -top-4 -right-4 text-8xl font-black text-white/5 select-none">3</div>
					<h3 class="text-xl font-bold text-white mb-3">3. Montaje y Configuración</h3>
					<p class="text-slate-400 text-sm leading-relaxed">
						Canalizamos el cableado (UTP exterior), montamos las cámaras y configuramos el DVR/NVR para visualización en tu celular y respaldo en la nube.
					</p>
				</div>
			</div>
		</section>

		<!-- CÓMO TRABAJAMOS -->
		<section class="relative z-10 mx-auto max-w-5xl px-6 w-full py-16 border-t border-white/5">
			<h2 class="text-2xl md:text-4xl font-extrabold text-white text-center mb-12">
				Nuestra Metodología de Trabajo
			</h2>
			<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
				<div class="space-y-6">
					<div class="flex gap-4 items-start">
						<div class="p-3 bg-brand-cyan/10 rounded-xl text-brand-cyan border border-brand-cyan/20 shrink-0">
							<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
						</div>
						<div>
							<h3 class="text-lg font-bold text-white mb-1">Tiempos de Ejecución</h3>
							<p class="text-slate-400 text-sm leading-relaxed">
								Instalaciones residenciales estándar (4 a 8 cámaras) se realizan en 1 a 2 jornadas de trabajo para no interrumpir tu rutina diaria.
							</p>
						</div>
					</div>
					<div class="flex gap-4 items-start">
						<div class="p-3 bg-brand-green/10 rounded-xl text-brand-green border border-brand-green/20 shrink-0">
							<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
						</div>
						<div>
							<h3 class="text-lg font-bold text-white mb-1">Garantía de Instalación</h3>
							<p class="text-slate-400 text-sm leading-relaxed">
								Garantía técnica de 1 año en el cableado, canalización y montaje estructural, además de la garantía oficial del fabricante en los equipos Hikvision o Dahua.
							</p>
						</div>
					</div>
				</div>
				<div class="space-y-6">
					<div class="flex gap-4 items-start">
						<div class="p-3 bg-brand-cyan/10 rounded-xl text-brand-cyan border border-brand-cyan/20 shrink-0">
							<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>
						</div>
						<div>
							<h3 class="text-lg font-bold text-white mb-1">Marcas y Herramientas Líderes</h3>
							<p class="text-slate-400 text-sm leading-relaxed">
								Utilizamos marcas profesionales de renombre como Hikvision, Dahua y Hilook. Instalamos cable 100% cobre para evitar pérdidas de señal y caídas de video.
							</p>
						</div>
					</div>
					<div class="flex gap-4 items-start">
						<div class="p-3 bg-brand-green/10 rounded-xl text-brand-green border border-brand-green/20 shrink-0">
							<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
						</div>
						<div>
							<h3 class="text-lg font-bold text-white mb-1">Capacitación y Configuración</h3>
							<p class="text-slate-400 text-sm leading-relaxed">
								Al finalizar la instalación, te dejamos configurada la aplicación en tus dispositivos y te enseñamos a revisar grabaciones paso a paso.
							</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- PORTAFOLIO DE PROYECTOS -->
		<section class="relative z-10 mx-auto max-w-5xl px-6 w-full py-16 border-t border-white/5">
			<h2 class="text-2xl md:text-4xl font-extrabold text-white text-center mb-12">
				Casos de Éxito en <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-cyan to-brand-green">Terreno</span>
			</h2>
			<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
				<div class="bg-zinc-950/50 border border-white/5 rounded-2xl overflow-hidden group hover:border-brand-green/20 transition-all duration-300">
					<div class="h-64 overflow-hidden relative">
						<img src="/imagenes/cctv.jpg" alt="Instalación de Cámaras de Seguridad" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
					</div>
					<div class="p-6 space-y-2">
						<h3 class="text-lg font-bold text-white">Sistema CCTV IP Hikvision de 4MP</h3>
						<p class="text-slate-400 text-xs">
							Instalación de seguridad integral en local comercial en Santiago Centro. Incluye 6 cámaras bullet con analítica de cruce de línea y grabador NVR con visualización remota de baja latencia.
						</p>
					</div>
				</div>
				<div class="bg-zinc-950/50 border border-white/5 rounded-2xl overflow-hidden group hover:border-brand-green/20 transition-all duration-300">
					<div class="h-64 overflow-hidden relative">
						<img src="/imagenes/principal.jpg" alt="Instalación en Condominio" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
					</div>
					<div class="p-6 space-y-2">
						<h3 class="text-lg font-bold text-white">Monitoreo Perimetral en Condominio Residencial</h3>
						<p class="text-slate-400 text-xs">
							Instalación de cámaras tipo domo antivandálico IK10 en accesos y perímetros del recinto. Sistema centralizado en sala de conserjería con respaldo de 30 días de grabaciones ininterrumpidas.
						</p>
					</div>
				</div>
			</div>
		</section>
	</main>

	<Footer />
	<WhatsAppButton phone="56948672300" message="Hola SERVITECNOLOGY, consulto por CCTV..." />
</Layout>
