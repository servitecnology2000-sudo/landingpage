---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WhatsAppButton from '../components/WhatsAppButton.astro';

const serviceTitle = "Soporte Técnico Especializado";
const serviceDescription = "Diagnóstico integral, mantenimiento preventivo/correctivo y optimización avanzada de laptops, computadores y consolas de videojuegos. Devolvemos el rendimiento original a tus equipos en Santiago.";
const waMessage = encodeURIComponent(`Hola SERVITECNOLOGY, requiero soporte técnico especializado para mis equipos.`);
const waLink = `https://wa.me/56948672300?text=${waMessage}`;
---

<Layout 
	title={`${serviceTitle} | SERVITECNOLOGY`} 
	description={serviceDescription}
	keywords="soporte tecnico, reparacion de computadores, reparar notebook, limpiar consola, mantencion pc, santiago"
>
	<Header />

	<main class="relative bg-black min-h-screen pt-24 pb-20 overflow-hidden">
		<!-- Background Glows -->
		<div class="absolute top-1/4 left-1/4 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-brand-cyan/5 rounded-full blur-[140px] pointer-events-none"></div>
		<div class="absolute bottom-1/4 right-1/4 translate-x-1/2 translate-y-1/2 w-[500px] h-[500px] bg-brand-green/5 rounded-full blur-[140px] pointer-events-none"></div>

		<!-- HERO SECTION -->
		<section class="relative z-10 mx-auto max-w-5xl px-6 w-full text-center py-12 md:py-20 space-y-6">
			<div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-brand-cyan/20 bg-brand-cyan/5 text-brand-cyan text-sm font-semibold uppercase tracking-wider">
				Servicio Técnico
			</div>
			<h1 class="text-4xl md:text-6xl font-extrabold tracking-tight text-white leading-tight">
				Soporte Técnico <br class="hidden sm:inline" />
				<span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-cyan to-brand-green">
					Especializado y Garantizado
				</span>
			</h1>
			<p class="text-slate-400 text-lg md:text-xl max-w-3xl mx-auto leading-relaxed">
				{serviceDescription}
			</p>
			<div class="pt-6">
				<a 
					href={waLink}
					target="_blank"
					rel="noopener noreferrer"
					class="inline-flex justify-center items-center gap-3 bg-brand-cyan text-black hover:bg-brand-green px-8 py-4 md:py-5 rounded-xl font-bold text-lg transition-all duration-300 shadow-[0_0_20px_rgba(0,207,255,0.2)] hover:scale-105"
				>
					Solicitar Soporte Ahora
					<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
				</a>
			</div>
		</section>

		<!-- PROCESO DE CONTRATACIÓN -->
		<section class="relative z-10 mx-auto max-w-5xl px-6 w-full py-16 border-t border-white/5">
			<h2 class="text-2xl md:text-4xl font-extrabold text-white text-center mb-12">
				Proceso de Contratación <span class="text-brand-cyan">Paso a Paso</span>
			</h2>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
				<div class="bg-zinc-950/50 border border-white/5 p-6 rounded-2xl relative overflow-hidden group hover:border-brand-cyan/20 transition-all duration-300">
					<div class="absolute -top-4 -right-4 text-8xl font-black text-white/5 select-none">1</div>
					<h3 class="text-xl font-bold text-white mb-3">1. Contacto y Diagnóstico</h3>
					<p class="text-slate-400 text-sm leading-relaxed">
						Nos escribes por WhatsApp describiendo la falla de tu equipo. Te damos una pre-evaluación y coordinamos la recepción.
					</p>
				</div>
				<div class="bg-zinc-950/50 border border-white/5 p-6 rounded-2xl relative overflow-hidden group hover:border-brand-cyan/20 transition-all duration-300">
					<div class="absolute -top-4 -right-4 text-8xl font-black text-white/5 select-none">2</div>
					<h3 class="text-xl font-bold text-white mb-3">2. Revisión y Cotización</h3>
					<p class="text-slate-400 text-sm leading-relaxed">
						Revisamos detalladamente el hardware/software en el taller. Te enviamos el diagnóstico formal y el presupuesto para aprobación.
					</p>
				</div>
				<div class="bg-zinc-950/50 border border-white/5 p-6 rounded-2xl relative overflow-hidden group hover:border-brand-cyan/20 transition-all duration-300">
					<div class="absolute -top-4 -right-4 text-8xl font-black text-white/5 select-none">3</div>
					<h3 class="text-xl font-bold text-white mb-3">3. Reparación y Entrega</h3>
					<p class="text-slate-400 text-sm leading-relaxed">
						Procedemos con la mantención o reparación. Hacemos pruebas de rendimiento y te entregamos tu equipo 100% operativo con garantía escrita.
					</p>
				</div>
			</div>
		</section>

		<!-- CÓMO TRABAJAMOS -->
		<section class="relative z-10 mx-auto max-w-5xl px-6 w-full py-16 border-t border-white/5">
			<h2 class="text-2xl md:text-4xl font-extrabold text-white text-center mb-12">
				Cómo Trabajamos
			</h2>
			<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
				<div class="space-y-6">
					<div class="flex gap-4 items-start">
						<div class="p-3 bg-brand-cyan/10 rounded-xl text-brand-cyan border border-brand-cyan/20 shrink-0">
							<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
						</div>
						<div>
							<h3 class="text-lg font-bold text-white mb-1">Tiempos de Respuesta</h3>
							<p class="text-slate-400 text-sm leading-relaxed">
								Diagnóstico rápido en 24 a 48 horas hábiles. Reparaciones express sujetas a disponibilidad de repuestos.
							</p>
						</div>
					</div>
					<div class="flex gap-4 items-start">
						<div class="p-3 bg-brand-green/10 rounded-xl text-brand-green border border-brand-green/20 shrink-0">
							<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"></path></svg>
						</div>
						<div>
							<h3 class="text-lg font-bold text-white mb-1">Garantía del Taller</h3>
							<p class="text-slate-400 text-sm leading-relaxed">
								Todas nuestras reparaciones de hardware cuentan con garantía real de 3 meses para tu total tranquilidad.
							</p>
						</div>
					</div>
				</div>
				<div class="space-y-6">
					<div class="flex gap-4 items-start">
						<div class="p-3 bg-brand-cyan/10 rounded-xl text-brand-cyan border border-brand-cyan/20 shrink-0">
							<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
									<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
							</svg>
						</div>
						<div>
							<h3 class="text-lg font-bold text-white mb-1">Herramientas Profesionales</h3>
							<p class="text-slate-400 text-sm leading-relaxed">
								Utilizamos insumos premium (pastas térmicas Arctic MX-4/MX-6) y herramientas de precisión para diagnóstico de placas y microsoldadura.
							</p>
						</div>
					</div>
					<div class="flex gap-4 items-start">
						<div class="p-3 bg-brand-green/10 rounded-xl text-brand-green border border-brand-green/20 shrink-0">
							<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path></svg>
						</div>
						<div>
							<h3 class="text-lg font-bold text-white mb-1">Metodología Transparente</h3>
							<p class="text-slate-400 text-sm leading-relaxed">
								Te mantenemos informado en todo momento. No realizamos ningún trabajo ni cambio de piezas sin tu autorización y presupuesto aprobado.
							</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- PORTAFOLIO DE PROYECTOS -->
		<section class="relative z-10 mx-auto max-w-5xl px-6 w-full py-16 border-t border-white/5">
			<h2 class="text-2xl md:text-4xl font-extrabold text-white text-center mb-12">
				Casos de Éxito y <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-cyan to-brand-green">Trabajos Realizados</span>
			</h2>
			<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
				<div class="bg-zinc-950/50 border border-white/5 rounded-2xl overflow-hidden group hover:border-brand-green/20 transition-all duration-300">
					<div class="h-64 overflow-hidden relative">
						<img src="/imagenes/soporte.jpg" alt="Mantención de Notebook Gamer" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
					</div>
					<div class="p-6 space-y-2">
						<h3 class="text-lg font-bold text-white">Reacondicionamiento Térmico ASUS ROG</h3>
						<p class="text-slate-400 text-xs">
							Notebook gamer presentaba thermal throttling y temperaturas sobre 95°C. Se realizó limpieza profunda interna y cambio de metal líquido / thermal pads. Temperaturas reducidas a 74°C estables en carga.
						</p>
					</div>
				</div>
				<div class="bg-zinc-950/50 border border-white/5 rounded-2xl overflow-hidden group hover:border-brand-green/20 transition-all duration-300">
					<div class="h-64 overflow-hidden relative">
						<img src="/imagenes/principal.jpg" alt="Reparación de Computador de Escritorio" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
					</div>
					<div class="p-6 space-y-2">
						<h3 class="text-lg font-bold text-white">Resurrección de PC de Oficina Post Cortocircuito</h3>
						<p class="text-slate-400 text-xs">
							Equipo no encendía por sobretensión en puerto USB frontal. Se aisló el corto en placa base, se reemplazaron los componentes dañados en la línea de 5V y se instaló fuente certificada para protección futura.
						</p>
					</div>
				</div>
			</div>
		</section>
	</main>

	<Footer />
	<WhatsAppButton phone="56948672300" message="Hola SERVITECNOLOGY, requiero soporte técnico..." />
</Layout>
