---
export const prerender = false;

import { supabase } from '../../../lib/supabase';

// Auth guard — read ADMIN_SECRET at runtime via process.env
const _runtimeEnv = typeof process !== 'undefined' ? process.env : ({} as Record<string, string>);
const adminSecret = _runtimeEnv['ADMIN_SECRET'] || import.meta.env.ADMIN_SECRET || '';
const cookie = Astro.cookies.get('admin_session');
if (cookie?.value !== adminSecret) {
	return Astro.redirect('/admin/login');
}

const { id } = Astro.params;

// Fetch product data
const { data: product, error: fetchError } = await supabase
	.from('repuestos_productos')
	.select('*')
	.eq('id', id)
	.single();

if (fetchError || !product) {
	return Astro.redirect('/admin');
}

let errorMsg = '';
let successMsg = '';

if (Astro.request.method === 'POST') {
	try {
		const formData = await Astro.request.formData();
		
		const sku = formData.get('sku')?.toString().trim() || '';
		const titulo = formData.get('titulo')?.toString().trim() || '';
		const slug = formData.get('slug')?.toString().trim() || '';
		const descripcion = formData.get('descripcion')?.toString().trim() || '';
		const categoria = formData.get('categoria')?.toString().trim() || '';
		const estado = formData.get('estado')?.toString().trim() || 'Usado Verificado';
		const precio_venta = parseFloat(formData.get('precio_venta')?.toString() || '0');
		const precio_costo = parseFloat(formData.get('precio_costo')?.toString() || '0');
		const stock_disponible = formData.get('stock_disponible') === 'true';
		
		// Parse compatibility tags
		const compatibilidadInput = formData.get('compatibilidad')?.toString() || '';
		const compatibilidad = compatibilidadInput
			.split(',')
			.map(tag => tag.trim())
			.filter(tag => tag.length > 0);

		// Parse SEO fields
		const seo_titulo = formData.get('seo_titulo')?.toString().trim() || '';
		const seo_descripcion = formData.get('seo_descripcion')?.toString().trim() || '';
		const seo_keywords = formData.get('seo_keywords')?.toString().trim() || '';

		// Process images
		const files = formData.getAll('imagenes');
		const newUrls: string[] = [];

		for (const fileItem of files) {
			const file = fileItem as File;
			if (file && file.size > 0) {
				const fileExt = file.name.split('.').pop();
				const fileName = `${Date.now()}-${Math.random().toString(36).substring(2, 9)}.${fileExt}`;
				const arrayBuffer = await file.arrayBuffer();
				const fileData = new Uint8Array(arrayBuffer);

				const { data: uploadData, error: uploadError } = await supabase.storage
					.from('imagenes-repuestos')
					.upload(fileName, fileData, {
						contentType: file.type
					});

				if (uploadError) {
					console.error('Storage Upload Error:', uploadError);
					throw new Error(`Error subiendo imagen: ${uploadError.message}`);
				}

				const { data: urlData } = supabase.storage
					.from('imagenes-repuestos')
					.getPublicUrl(fileName);

				if (urlData?.publicUrl) {
					newUrls.push(urlData.publicUrl);
				}
			}
		}

		// Choose to merge or overwrite images
		// If new images are uploaded, append them to existing ones, or keep old ones if none uploaded
		const existingImages: string[] = product.imagenes ?? [];
		const keepOldImages = formData.get('keep_old_images') === 'true';
		
		let finalUrls = existingImages;
		if (newUrls.length > 0) {
			if (keepOldImages) {
				finalUrls = [...existingImages, ...newUrls].slice(0, 3);
			} else {
				finalUrls = newUrls.slice(0, 3);
			}
		}

		// Update database
		const { data: updateData, error: updateError } = await supabase
			.from('repuestos_productos')
			.update({
				sku,
				titulo,
				slug,
				descripcion,
				categoria,
				estado,
				precio_venta,
				precio_costo,
				compatibilidad,
				stock_disponible,
				imagenes: finalUrls,
				seo_titulo,
				seo_descripcion,
				seo_keywords
			})
			.eq('id', id);

		if (updateError) {
			console.error('Database Update Error:', updateError);
			throw new Error(`Error en base de datos: ${updateError.message}`);
		}

		return Astro.redirect('/admin');
	} catch (err: any) {
		errorMsg = err.message || 'Ocurrió un error inesperado';
	}
}
---

<html lang="es">
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width" />
	<meta name="robots" content="noindex, nofollow" />
	<title>SERVITECH Admin — Editar Producto</title>
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
	<style>
		* { margin: 0; padding: 0; box-sizing: border-box; }
		body { font-family: 'Inter', sans-serif; background: #09090b; color: #e2e8f0; min-height: 100vh; padding-bottom: 4rem; }
		.topbar { background: rgba(24,24,27,0.9); border-bottom: 1px solid rgba(255,255,255,0.05); padding: 1rem 2rem; display: flex; align-items: center; justify-content: space-between; backdrop-filter: blur(12px); position: sticky; top: 0; z-index: 50; }
		.brand { font-family: 'Outfit', sans-serif; font-weight: 800; font-size: 1.25rem; background: linear-gradient(to right, #00FF7F, #00CFFF); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
		.btn { display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.5rem 1rem; border-radius: 0.5rem; font-size: 0.75rem; font-weight: 600; text-decoration: none; cursor: pointer; transition: all 0.2s; border: none; }
		.btn-primary { background: linear-gradient(to right, #00CFFF, #00FF7F); color: black; }
		.btn-primary:hover { opacity: 0.9; }
		.btn-outline { background: transparent; border: 1px solid rgba(255,255,255,0.1); color: #94a3b8; }
		.btn-outline:hover { border-color: #00CFFF; color: #00CFFF; }
		.container { max-width: 800px; margin: 0 auto; padding: 2rem; }
		h2 { font-family: 'Outfit', sans-serif; font-size: 1.5rem; font-weight: 800; color: white; margin-bottom: 1.5rem; border-bottom: 1px solid rgba(255,255,255,0.05); pb: 0.75rem; }
		.card { background: rgba(24,24,27,0.6); border: 1px solid rgba(255,255,255,0.05); border-radius: 0.75rem; padding: 2rem; }
		.form-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem; }
		.col-full { grid-column: span 2; }
		.field { display: flex; flex-direction: column; gap: 0.4rem; }
		label { font-size: 0.7rem; font-weight: 600; color: #94a3b8; text-transform: uppercase; letter-spacing: 0.05em; }
		input, select, textarea { width: 100%; padding: 0.75rem 1rem; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 0.5rem; color: white; font-size: 0.875rem; outline: none; transition: border-color 0.3s; }
		input:focus, select:focus, textarea:focus { border-color: #00CFFF; }
		textarea { height: 100px; resize: vertical; }
		.checkbox-field { flex-direction: row; align-items: center; gap: 0.75rem; margin-top: 0.5rem; }
		.checkbox-field input { width: auto; cursor: pointer; }
		.section-title { font-family: 'Outfit', sans-serif; font-size: 1.1rem; font-weight: 700; color: #00CFFF; margin-top: 1rem; margin-bottom: 0.5rem; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 0.25rem; }
		.actions { display: flex; gap: 1rem; justify-content: flex-end; margin-top: 2rem; border-top: 1px solid rgba(255,255,255,0.05); padding-top: 1.5rem; }
		.error-box { background: rgba(239,68,68,0.1); border: 1px solid rgba(239,68,68,0.2); color: #f87171; padding: 1rem; border-radius: 0.5rem; margin-bottom: 1.5rem; font-size: 0.8rem; }
		.image-preview-list { display: flex; gap: 1rem; margin-top: 0.5rem; }
		.image-preview-item { relative; border: 1px solid rgba(255,255,255,0.1); border-radius: 0.5rem; overflow: hidden; width: 80px; height: 60px; }
		.image-preview-item img { width: 100%; height: 100%; object-fit: cover; }
		@media (max-width: 640px) {
			.form-grid { grid-template-columns: 1fr; }
			.col-full { grid-column: span 1; }
		}
	</style>
</head>
<body>
	<div class="topbar">
		<span class="brand">SERVITECH Admin</span>
		<a href="/admin" class="btn btn-outline">Volver al Panel</a>
	</div>

	<div class="container">
		<h2>Editar Repuesto / Componente</h2>

		{errorMsg && <div class="error-box">{errorMsg}</div>}

		<div class="card">
			<form method="POST" enctype="multipart/form-data">
				<div class="form-grid">
					<!-- SKU -->
					<div class="field">
						<label for="sku">SKU (Número de Parte)</label>
						<input type="text" id="sku" name="sku" value={product.sku} placeholder="Ej: PANT-156-IPS" required />
					</div>

					<!-- Categoría -->
					<div class="field">
						<label for="categoria">Categoría</label>
						<select id="categoria" name="categoria" required>
							<option value="pantallas" selected={product.categoria === 'pantallas'}>Pantallas</option>
							<option value="teclados" selected={product.categoria === 'teclados'}>Teclados</option>
							<option value="almacenamiento" selected={product.categoria === 'almacenamiento'}>Almacenamiento</option>
							<option value="ram" selected={product.categoria === 'ram'}>RAM</option>
						</select>
					</div>

					<!-- Título -->
					<div class="field col-full">
						<label for="titulo">Título de Producto</label>
						<input type="text" id="titulo" name="titulo" value={product.titulo} placeholder="Ej: Pantalla LED 15.6 pulgadas IPS" required />
					</div>

					<!-- Slug -->
					<div class="field col-full">
						<label for="slug">Slug (URL amigable)</label>
						<input type="text" id="slug" name="slug" value={product.slug} placeholder="pantalla-led-15-6-ips" required />
					</div>

					<!-- Descripción -->
					<div class="field col-full">
						<label for="descripcion">Descripción</label>
						<textarea id="descripcion" name="descripcion" placeholder="Menciona detalles técnicos del repuesto..." required>{product.descripcion}</textarea>
					</div>

					<!-- Estado -->
					<div class="field">
						<label for="estado">Estado del Repuesto</label>
						<select id="estado" name="estado">
							<option value="Usado Verificado" selected={product.estado === 'Usado Verificado'}>Usado Verificado</option>
							<option value="Nuevo" selected={product.estado === 'Nuevo'}>Nuevo</option>
							<option value="Reacondicionado" selected={product.estado === 'Reacondicionado'}>Reacondicionado</option>
						</select>
					</div>

					<!-- Stock disponible -->
					<div class="field checkbox-field">
						<input type="checkbox" id="stock_disponible" name="stock_disponible_check" checked={product.stock_disponible} />
						<input type="hidden" id="stock_disponible_val" name="stock_disponible" value={product.stock_disponible ? 'true' : 'false'} />
						<label for="stock_disponible">Disponible en Stock</label>
					</div>

					<!-- Precio Venta -->
					<div class="field">
						<label for="precio_venta">Precio de Venta (CLP)</label>
						<input type="number" id="precio_venta" name="precio_venta" value={product.precio_venta} placeholder="Ej: 45000" min="0" required />
					</div>

					<!-- Precio Costo -->
					<div class="field">
						<label for="precio_costo">Precio de Costo (Oculto) (CLP)</label>
						<input type="number" id="precio_costo" name="precio_costo" value={product.precio_costo} placeholder="Ej: 22000" min="0" required />
					</div>

					<!-- Compatibilidad -->
					<div class="field col-full">
						<label for="compatibilidad">Compatibilidad (Modelos separados por comas)</label>
						<input type="text" id="compatibilidad" name="compatibilidad" value={product.compatibilidad ? product.compatibilidad.join(', ') : ''} placeholder="Ej: Lenovo ThinkPad E15, Dell Latitude 3510" />
					</div>

					<!-- Existing Images Preview -->
					{product.imagenes && product.imagenes.length > 0 && (
						<div class="field col-full">
							<label>Imágenes Actuales</label>
							<div class="image-preview-list">
								{product.imagenes.map((img: string) => (
									<div class="image-preview-item">
										<img src={img} alt="" />
									</div>
								))}
							</div>
							<div class="checkbox-field" style="margin-top:0.75rem;">
								<input type="checkbox" id="keep_old_images" name="keep_old_images" value="true" checked />
								<label for="keep_old_images" style="text-transform:none; font-size:0.75rem;">Mantener imágenes actuales al subir nuevas (hasta el límite de 3)</label>
							</div>
						</div>
					)}

					<!-- Imágenes (Max 3) -->
					<div class="field col-full">
						<label>Subir Nuevas Imágenes</label>
						<input type="file" name="imagenes" accept="image/*" style="margin-bottom:0.5rem;" />
						<input type="file" name="imagenes" accept="image/*" style="margin-bottom:0.5rem;" />
						<input type="file" name="imagenes" accept="image/*" />
					</div>

					<!-- SEO Title -->
					<div class="col-full section-title">SEO Dinámico</div>

					<div class="field col-full">
						<label for="seo_titulo">Título SEO (meta title)</label>
						<input type="text" id="seo_titulo" name="seo_titulo" value={product.seo_titulo} placeholder="Ej: Comprar Pantalla 15.6 IPS en Santiago" />
					</div>

					<div class="field col-full">
						<label for="seo_descripcion">Meta Descripción</label>
						<textarea id="seo_descripcion" name="seo_descripcion" placeholder="Ej: Pantalla original usada de repuesto testeada con garantía de stock...">{product.seo_descripcion}</textarea>
					</div>

					<div class="field col-full">
						<label for="seo_keywords">Keywords (separadas por comas)</label>
						<input type="text" id="seo_keywords" name="seo_keywords" value={product.seo_keywords} placeholder="Ej: repuesto notebook, pantalla lenovo" />
					</div>

				</div>

				<div class="actions">
					<a href="/admin" class="btn btn-outline">Cancelar</a>
					<button type="submit" class="btn btn-primary" style="padding:0.75rem 1.5rem;">Actualizar Producto</button>
				</div>
			</form>
		</div>
	</div>

	<script>
		// Automatically generate slug from Title (only if it changes or user wants it)
		const tituloInput = document.getElementById('titulo') as HTMLInputElement;
		const slugInput = document.getElementById('slug') as HTMLInputElement;

		tituloInput?.addEventListener('input', () => {
			const text = tituloInput.value;
			const slug = text
				.toLowerCase()
				.normalize('NFD')
				.replace(/[\u0300-\u036f]/g, '')
				.replace(/[^a-z0-9\s-]/g, '')
				.trim()
				.replace(/\s+/g, '-')
				.replace(/-+/g, '-');
			slugInput.value = slug;
		});

		// Sync stock checkbox to hidden input
		const stockCheckbox = document.getElementById('stock_disponible') as HTMLInputElement;
		const stockHidden = document.getElementById('stock_disponible_val') as HTMLInputElement;
		stockCheckbox?.addEventListener('change', () => {
			stockHidden.value = stockCheckbox.checked ? 'true' : 'false';
		});
	</script>
</body>
</html>
