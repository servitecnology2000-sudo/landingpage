---
export const prerender = false;

const _env = typeof process !== 'undefined' ? process.env : ({} as Record<string, string>);
const adminSecret = _env['ADMIN_SECRET'] || import.meta.env.ADMIN_SECRET || '20181860';

const cookie = Astro.cookies.get('admin_session');
if (cookie?.value === adminSecret) {
	return Astro.redirect('/admin');
}

let error = '';
if (Astro.request.method === 'POST') {
	const formData = await Astro.request.formData();
	const password = formData.get('password')?.toString();
	if (password === adminSecret) {
		Astro.cookies.set('admin_session', adminSecret, {
			path: '/',
			httpOnly: true,
			secure: true,
			sameSite: 'lax',
			maxAge: 60 * 60 * 24
		});
		return Astro.redirect('/admin');
	} else {
		error = 'Contraseña incorrecta';
	}
}
---

<html lang="es">
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width" />
	<meta name="robots" content="noindex, nofollow" />
	<title>SERVITECH Admin — Iniciar Sesión</title>
	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
	<style>
		* { margin: 0; padding: 0; box-sizing: border-box; }
		body { font-family: 'Inter', sans-serif; background: #09090b; color: #e2e8f0; min-height: 100vh; display: flex; align-items: center; justify-content: center; }
		.login-card { background: rgba(24,24,27,0.8); border: 1px solid rgba(255,255,255,0.1); border-radius: 1rem; padding: 2.5rem; width: 100%; max-width: 420px; backdrop-filter: blur(12px); box-shadow: 0 25px 50px -12px rgba(0,0,0,0.8); }
		h1 { font-family: 'Outfit', sans-serif; font-size: 1.5rem; font-weight: 800; text-align: center; margin-bottom: 0.5rem; }
		.brand { background: linear-gradient(to right, #00FF7F, #00CFFF); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
		.subtitle { text-align: center; font-size: 0.8rem; color: #94a3b8; margin-bottom: 2rem; }
		label { display: block; font-size: 0.75rem; font-weight: 600; color: #94a3b8; margin-bottom: 0.5rem; text-transform: uppercase; letter-spacing: 0.05em; }
		input { width: 100%; padding: 0.75rem 1rem; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 0.5rem; color: white; font-size: 0.875rem; outline: none; transition: border-color 0.3s; }
		input:focus { border-color: #00CFFF; }
		button { width: 100%; margin-top: 1.5rem; padding: 0.75rem; background: linear-gradient(to right, #00CFFF, #00FF7F); color: black; font-weight: 700; font-size: 0.875rem; border: none; border-radius: 0.5rem; cursor: pointer; transition: opacity 0.3s; }
		button:hover { opacity: 0.9; }
		.error { color: #f87171; font-size: 0.75rem; text-align: center; margin-top: 1rem; }
		.back { display: block; text-align: center; margin-top: 1.5rem; color: #64748b; font-size: 0.75rem; text-decoration: none; }
		.back:hover { color: #00CFFF; }
	</style>
</head>
<body>
	<div class="login-card">
		<h1><span class="brand">SERVITECH</span> Admin</h1>
		<p class="subtitle">Panel de administración privado</p>
		<form method="POST">
			<label for="password">Contraseña de acceso</label>
			<input type="password" id="password" name="password" placeholder="Ingresa la contraseña" required autofocus />
			<button type="submit">Ingresar al Panel</button>
		</form>
		{error && <p class="error">{error}</p>}
		<a href="/" class="back">← Volver al sitio</a>
	</div>
</body>
</html>
