---
import '../styles/global.css';
import Lightbox from '../components/Lightbox.astro';

interface Props {
	title?: string;
	description?: string;
	keywords?: string;
}

const { 
	title = "SERVITECH - Soluciones Informáticas, Consultoría y Soporte IT",
	description = "Soluciones informáticas profesionales, consultoría de sistemas y soporte IT para empresas y particulares. Optimiza tu infraestructura tecnológica con SERVITECH.",
	keywords = "soporte tecnico, reparacion computadores, informatica, CCTV, redes, santiago"
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- SEO Tags -->
		<title>{title}</title>
		
		<!-- Google Fonts: Outfit (modern, tech, geometric) & Inter -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
	</head>
	<body class="bg-dark-bg text-slate-100 font-sans min-h-screen flex flex-col antialiased selection:bg-brand-cyan/30 selection:text-brand-cyan">
		<slot />
		
		<script>
			import { supabase } from '../lib/supabase';
			
			// Solo trackear si no estamos en el admin
			if (!window.location.pathname.startsWith('/admin')) {
				const trackEvent = async (tipo: string, elemento_id: string | null = null) => {
					try {
						await supabase.from('metricas_eventos').insert([
							{
								tipo_evento: tipo,
								elemento_id: elemento_id,
								url_origen: window.location.pathname
							}
						]);
					} catch(e) {
						console.warn('Tracking error', e);
					}
				};

				// 1. Registrar visita inicial
				trackEvent('visita_pagina');

				// 2. Escuchar clics delegados
				document.addEventListener('click', (e) => {
					const target = (e.target as HTMLElement).closest('[data-track-event]');
					if (target) {
						const tipo = target.getAttribute('data-track-event');
						const elemento = target.getAttribute('data-element-id');
						if (tipo) {
							trackEvent(tipo, elemento);
						}
					}
				});
			}
		</script>
		<Lightbox />
	</body>
</html>

<style is:global>
	/* Custom font definitions and custom styles */
	:root {
		font-family: 'Inter', sans-serif;
	}
	
	h1, h2, h3, h4, h5, h6 {
		font-family: 'Outfit', sans-serif;
	}
</style>
