---
import '../styles/global.css';
import Lightbox from '../components/Lightbox.astro';

interface Props {
	title?: string;
	description?: string;
	keywords?: string;
}

const { 
	title = "SERVITECNOLOGY - Soluciones Informáticas, Consultoría y Soporte IT",
	description = "Soluciones informáticas profesionales, consultoría de sistemas y soporte IT para empresas y particulares. Optimiza tu infraestructura tecnológica con SERVITECNOLOGY.",
	keywords = "soporte tecnico, reparacion computadores, informatica, CCTV, redes, santiago"
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="keywords" content={keywords} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" href="/imagenes/favico.png" type="image/png" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- SEO Tags -->
		<title>{title}</title>
		
		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://servitecnology.com/" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content="https://servitecnology.com/imagenes/principal.jpg" />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content="https://servitecnology.com/" />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content="https://servitecnology.com/imagenes/principal.jpg" />

		<!-- JSON-LD LocalBusiness & Organization Schema for Google and AI search engines -->
		<script type="application/ld+json" is:inline>
			{
				"@context": "https://schema.org",
				"@type": ["LocalBusiness", "Organization"],
				"name": "SERVITECNOLOGY",
				"image": "https://servitecnology.com/imagenes/principal.jpg",
				"url": "https://servitecnology.com/",
				"telephone": "+56948672300",
				"email": "contacto@servitecnology.com",
				"priceRange": "$$",
				"address": {
					"@type": "PostalAddress",
					"addressLocality": "Santiago",
					"addressRegion": "Región Metropolitana",
					"postalCode": "8320000",
					"addressCountry": "CL"
				},
				"contactPoint": [
					{
						"@type": "ContactPoint",
						"email": "contacto@servitecnology.com",
						"contactType": "customer service",
						"availableLanguage": "Spanish"
					},
					{
						"@type": "ContactPoint",
						"email": "jesusleon@servitecnology.com",
						"contactType": "technical support",
						"availableLanguage": "Spanish"
					}
				],
				"openingHoursSpecification": [
					{
						"@type": "OpeningHoursSpecification",
						"dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
						"opens": "18:30",
						"closes": "22:00"
					}
				]
			}
		</script>

		<!-- Google Fonts: Outfit (modern, tech, geometric) & Inter -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
	</head>
	<body class="bg-dark-bg text-slate-100 font-sans min-h-screen flex flex-col antialiased selection:bg-brand-cyan/30 selection:text-brand-cyan">
		<slot />
		
		<script>
			import { supabase } from '../lib/supabase';
			
			// Solo trackear si no estamos en el admin
			if (!window.location.pathname.startsWith('/meson-servitecnology-st')) {
				const trackEvent = async (tipo: string, elemento_id: string | null = null) => {
					try {
						await supabase.from('metricas_eventos').insert([
							{
								tipo_evento: tipo,
								elemento_id: elemento_id,
								url_origen: window.location.pathname
							}
						]);
					} catch(e) {
						console.warn('Tracking error', e);
					}
				};

				// 1. Registrar visita inicial
				trackEvent('visita_pagina');

				// 2. Escuchar clics delegados
				document.addEventListener('click', (e) => {
					const target = (e.target as HTMLElement).closest('[data-track-event]');
					if (target) {
						const tipo = target.getAttribute('data-track-event');
						const elemento = target.getAttribute('data-element-id');
						if (tipo) {
							trackEvent(tipo, elemento);
						}
					}
				});
			}
		</script>
		<Lightbox />
	</body>
</html>

<style is:global>
	/* Custom font definitions and custom styles */
	:root {
		font-family: 'Inter', sans-serif;
	}
	
	h1, h2, h3, h4, h5, h6 {
		font-family: 'Outfit', sans-serif;
	}
</style>
