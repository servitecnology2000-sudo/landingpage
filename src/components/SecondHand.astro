---
import Button from './Button.astro';

interface ProductItem {
	id: string;
	title: string;
	badge: string;
	price: string;
	specs: {
		cpu: string;
		ram: string;
		storage: string;
		gpu: string;
		extra?: string;
	};
	whatsappMessage: string;
}

const products: ProductItem[] = [
	{
		id: "legion5",
		title: "Laptop Gamer Lenovo Legion 5",
		badge: "Reacondicionado A+",
		price: "$680.000",
		specs: {
			cpu: "AMD Ryzen 7 4800H (8 núcleos / 16 hilos)",
			ram: "16 GB DDR4 3200MHz",
			storage: "512 GB SSD NVMe M.2 de ultra velocidad",
			gpu: "NVIDIA GeForce RTX 3060 6GB GDDR6",
			extra: "Pantalla IPS 15.6\" 144Hz, Mantención completa realizada."
		},
		whatsappMessage: "Hola SERVITECH, me interesa consultar por la disponibilidad de la Laptop Gamer Lenovo Legion 5 Reacondicionada por $680.000."
	},
	{
		id: "officepro",
		title: "PC de Escritorio Intel Core i5 Office Pro",
		badge: "Reacondicionado Grado A",
		price: "$320.000",
		specs: {
			cpu: "Intel Core i5-10400 (6 núcleos / 12 hilos)",
			ram: "16 GB DDR4 Dual Channel",
			storage: "480 GB SSD SATA III",
			gpu: "Gráficos Intel® UHD 630",
			extra: "Gabinete slim corporativo, incluye teclado, mouse y monitor de 22\" FHD."
		},
		whatsappMessage: "Hola SERVITECH, me interesa consultar por la disponibilidad del PC de Escritorio Intel Core i5 Office Pro Reacondicionado por $320.000."
	}
];

const phone = "56948672300"; // WhatsApp contact phone
---

<section id="catalogo" class="relative py-24 bg-black overflow-hidden border-t border-white/5">
	<!-- Background glow decoration -->
	<div class="absolute bottom-0 right-0 w-[450px] h-[450px] bg-brand-green/5 rounded-full blur-[140px] pointer-events-none"></div>

	<div class="relative z-10 mx-auto max-w-6xl px-6 w-full">
		<!-- Section Header -->
		<div class="text-center max-w-3xl mx-auto mb-16 space-y-4">
			<div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-brand-cyan/20 bg-brand-cyan/5 text-brand-cyan text-xs font-semibold uppercase tracking-wider">
				Vitrina Comercial
			</div>
			<h2 class="text-3xl md:text-5xl font-extrabold tracking-tight text-white">
				Equipos de Segunda Mano <br class="hidden sm:inline" />
				<span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-green to-brand-cyan">
					Garantizados y Reacondicionados
				</span>
			</h2>
			<p class="text-slate-400 text-base md:text-lg">
				Equipos rigurosamente seleccionados, testeados, sometidos a mantenciones profundas y optimizados para rendir como nuevos.
			</p>
		</div>

		<!-- Products Grid -->
		<div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
			{products.map((product) => {
				const encodedMsg = encodeURIComponent(product.whatsappMessage);
				const whatsappLink = `https://wa.me/${phone}?text=${encodedMsg}`;
				
				return (
					<div class="relative group flex flex-col justify-between p-8 rounded-2xl border border-white/5 bg-zinc-950/60 backdrop-blur-sm transition-all duration-300 hover:border-brand-green/30 hover:shadow-[0_0_30px_rgba(0,255,127,0.03)] overflow-hidden">
						<!-- Glow highlight on card border -->
						<div class="absolute inset-0 bg-gradient-to-tr from-brand-green/5 via-transparent to-brand-cyan/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-2xl pointer-events-none"></div>
						
						<div>
							<!-- Header of Card -->
							<div class="flex items-start justify-between gap-4 mb-6">
								<h3 class="text-xl font-bold text-white group-hover:text-brand-green transition-colors duration-300">
									{product.title}
								</h3>
								<span class="text-[10px] font-semibold tracking-wide uppercase px-2.5 py-1 rounded-full bg-brand-green/10 text-brand-green border border-brand-green/20 whitespace-nowrap">
									{product.badge}
								</span>
							</div>

							<!-- Price Block -->
							<div class="flex items-baseline gap-2 mb-6">
								<span class="text-xs text-slate-500 uppercase tracking-wider font-semibold">Precio:</span>
								<span class="text-3xl font-extrabold text-brand-green tracking-tight">{product.price}</span>
								<span class="text-xs text-slate-400">CLP</span>
							</div>

							<!-- Specs Sheet -->
							<div class="space-y-3.5 border-t border-b border-white/5 py-6 mb-8 text-sm">
								<!-- CPU -->
								<div class="flex gap-3">
									<svg class="w-5 h-5 text-brand-cyan shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 5h10a2 2 0 012 2v10a2 2 0 01-2 2H7a2 2 0 01-2-2V7a2 2 0 012-2z" />
									</svg>
									<div>
										<span class="text-slate-400 block text-xs">Procesador</span>
										<span class="text-slate-200 font-medium">{product.specs.cpu}</span>
									</div>
								</div>
								
								<!-- RAM -->
								<div class="flex gap-3">
									<svg class="w-5 h-5 text-brand-cyan shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
									</svg>
									<div>
										<span class="text-slate-400 block text-xs">Memoria RAM</span>
										<span class="text-slate-200 font-medium">{product.specs.ram}</span>
									</div>
								</div>

								<!-- Storage -->
								<div class="flex gap-3">
									<svg class="w-5 h-5 text-brand-cyan shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" />
									</svg>
									<div>
										<span class="text-slate-400 block text-xs">Almacenamiento</span>
										<span class="text-slate-200 font-medium">{product.specs.storage}</span>
									</div>
								</div>

								<!-- GPU -->
								<div class="flex gap-3">
									<svg class="w-5 h-5 text-brand-cyan shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
									</svg>
									<div>
										<span class="text-slate-400 block text-xs">Tarjeta Gráfica</span>
										<span class="text-slate-200 font-medium">{product.specs.gpu}</span>
									</div>
								</div>

								{product.specs.extra && (
									<div class="pt-2 text-xs text-brand-green/80 font-medium italic">
										✨ {product.specs.extra}
									</div>
								)}
							</div>
						</div>

						<!-- Action CTA -->
						<Button href={whatsappLink} variant="secondary" class="w-full text-center tracking-wide" target="_blank" rel="noopener noreferrer">
							Consultar Disponibilidad
						</Button>
					</div>
				);
			})}
		</div>
	</div>
</section>
