---
interface ServiceItem {
	title: string;
	description: string;
	iconPath: string; // Used to identify the SVG icon
	image: string; // Image path for floating mockup
}

const services: ServiceItem[] = [
	{
		title: "Soporte Técnico Especializado",
		description: "Diagnóstico completo, mantenimiento preventivo/correctivo y optimización avanzada de laptops, PCs y consolas de videojuegos. Devolvemos el rendimiento original a tus equipos.",
		iconPath: "tools",
		image: "/imagenes/soporte.jpg"
	},
	{
		title: "Seguridad e Instalación de CCTV",
		description: "Diseño y montaje de sistemas de videovigilancia de alta definición, sistemas de alarmas y configuración integrada para el monitoreo remoto en tiempo real desde tu teléfono móvil.",
		iconPath: "camera",
		image: "/imagenes/cctv.jpg"
	},
	{
		title: "Armado de PCs y Modding Gaming",
		description: "Configuración personalizada de computadoras de alto rendimiento para gaming, streaming o diseño profesional. Maximizamos tu presupuesto seleccionando componentes con la mejor relación calidad-precio.",
		iconPath: "cpu",
		image: "/imagenes/gaming.jpg"
	},
	{
		title: "Redes y Conectividad",
		description: "Cableado estructurado de red, diagnóstico y optimización de señales Wi-Fi (para hogares u oficinas), configuración de routers avanzados y resolución definitiva de problemas de conectividad.",
		iconPath: "network",
		image: "/imagenes/redes.jpg"
	}
];
---

<section id="servicios" class="relative py-24 bg-black overflow-hidden">
	<!-- Background decorations -->
	<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-brand-cyan/5 rounded-full blur-[160px] pointer-events-none"></div>

	<div class="relative z-10 mx-auto max-w-7xl px-6 w-full">
		<!-- Section Header -->
		<div class="text-center max-w-3xl mx-auto mb-16 space-y-4">
			<div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-brand-green/20 bg-brand-green/5 text-brand-green text-xs font-semibold uppercase tracking-wider">
				Servicios Estrella
			</div>
			<h2 class="text-3xl md:text-5xl font-extrabold tracking-tight text-white">
				Soluciones Informáticas <br class="hidden sm:inline" />
				<span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-cyan to-brand-green">
					a la Medida de tus Necesidades
				</span>
			</h2>
			<p class="text-slate-400 text-base md:text-lg">
				Ofrecemos soporte integral garantizado con disponibilidad flexible. Tu tranquilidad tecnológica es nuestra prioridad.
			</p>
		</div>

		<!-- Services Grid -->
		<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
			{services.map((service) => (
				<div class="relative group p-6 sm:p-8 rounded-2xl border border-white/10 bg-zinc-950/70 backdrop-blur-md transition-all duration-500 hover:border-brand-cyan/30 hover:shadow-[0_20px_40px_rgba(0,207,255,0.08)] flex flex-col justify-between min-h-[380px] sm:min-h-[280px] md:min-h-[320px] lg:min-h-[300px] overflow-visible">
					<!-- Border glow animation on hover -->
					<div class="absolute inset-0 bg-gradient-to-br from-brand-cyan/5 to-brand-green/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500 rounded-2xl pointer-events-none"></div>

					<div class="relative z-10 flex flex-col sm:flex-row h-full w-full gap-6 justify-between items-stretch">
						<!-- Left: Text content -->
						<div class="w-full sm:w-[55%] flex flex-col justify-between z-10 space-y-4">
							<div class="space-y-4">
								<!-- Icon wrapper -->
								<div class="p-3 rounded-xl bg-white/5 text-brand-cyan group-hover:bg-brand-cyan/15 group-hover:text-brand-cyan transition-all duration-300 w-fit">
									{service.iconPath === "tools" && (
										<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
										</svg>
									)}
									{service.iconPath === "camera" && (
										<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
										</svg>
									)}
									{service.iconPath === "cpu" && (
										<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 5h10a2 2 0 012 2v10a2 2 0 01-2 2H7a2 2 0 01-2-2V7a2 2 0 012-2z" />
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 9h6v6H9V9z" />
										</svg>
									)}
									{service.iconPath === "network" && (
										<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
											<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5.121 17.804A13.937 13.937 0 0112 16c2.5 0 4.847.655 6.879 1.804M15 10a3 3 0 11-6 0 3 3 0 016 0zm6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
										</svg>
									)}
								</div>
								
								<h3 class="text-xl font-bold text-white group-hover:text-brand-cyan transition-colors duration-300">
									{service.title}
								</h3>
								
								<p class="text-sm text-slate-400 leading-relaxed">
									{service.description}
								</p>
							</div>
						</div>

						<!-- Right/Bottom: Floating Mockup Image -->
						<div class="relative w-full sm:w-[40%] min-h-[140px] sm:min-h-0 flex-1 overflow-visible">
							<div class="absolute bottom-[-12px] right-[-12px] sm:bottom-[-20px] sm:right-[-20px] w-[85%] sm:w-[130%] max-w-[200px] sm:max-w-none aspect-[4/3] rounded-xl overflow-hidden border border-white/15 shadow-[0_15px_30px_rgba(0,0,0,0.7)] transition-all duration-500 ease-out group-hover:translate-y-[-6px] group-hover:scale-[1.03] group-hover:shadow-[0_25px_40px_rgba(0,207,255,0.2)] group-hover:border-brand-cyan/40">
								<img src={service.image} alt={service.title} class="w-full h-full object-cover" />
							</div>
						</div>
					</div>
				</div>
			))}
		</div>
	</div>
</section>
