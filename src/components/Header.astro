---
import Button from './Button.astro';

interface NavItem {
	label: string;
	href: string;
}

const navItems: NavItem[] = [
	{ label: 'Servicios', href: '#servicios' },
	{ label: 'Catálogo', href: '#catalogo' },
];
---

<header class="sticky top-0 z-50 w-full border-b border-white/5 bg-black/75 backdrop-blur-md transition-all duration-300">
	<div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
		<!-- Brand Logo -->
		<a href="/" class="flex items-center gap-2 group">
			<span class="text-2xl font-extrabold tracking-wider bg-gradient-to-r from-brand-green to-brand-cyan bg-clip-text text-transparent group-hover:opacity-90 transition-opacity">
				SERVITECH
			</span>
		</a>

		<!-- Desktop Navigation -->
		<nav class="hidden md:flex items-center gap-8">
			{navItems.map((item) => (
				<a 
					href={item.href} 
					class="text-sm font-medium text-slate-300 hover:text-brand-cyan transition-colors duration-300 relative py-1 after:absolute after:bottom-0 after:left-0 after:h-[2px] after:w-0 after:bg-brand-cyan after:transition-all after:duration-300 hover:after:w-full"
				>
					{item.label}
				</a>
			))}
			<Button href="#contacto" variant="outline" class="px-5 py-2 text-xs">
				Contacto
			</Button>
		</nav>

		<!-- Mobile Menu Toggle Button -->
		<button 
			id="menu-toggle" 
			class="flex h-10 w-10 cursor-pointer items-center justify-center rounded-lg border border-white/10 text-slate-300 hover:bg-white/5 md:hidden focus:outline-none"
			aria-label="Abrir menú de navegación"
		>
			<svg id="menu-icon" class="h-6 w-6 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
			</svg>
			<svg id="close-icon" class="hidden h-6 w-6 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
				<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
			</svg>
		</button>
	</div>

	<!-- Mobile Menu Panel -->
	<div 
		id="mobile-menu" 
		class="hidden w-full border-t border-white/5 bg-black/95 px-6 py-6 md:hidden transition-all duration-300 ease-in-out"
	>
		<nav class="flex flex-col gap-4">
			{navItems.map((item) => (
				<a 
					href={item.href} 
					class="mobile-nav-link text-base font-medium text-slate-300 hover:text-brand-cyan transition-colors py-2 border-b border-white/5"
				>
					{item.label}
				</a>
			))}
			<div class="pt-4">
				<Button href="#contacto" variant="primary" class="w-full">
					Contacto
				</Button>
			</div>
		</nav>
	</div>
</header>

<script>
	const menuToggle = document.getElementById('menu-toggle');
	const mobileMenu = document.getElementById('mobile-menu');
	const menuIcon = document.getElementById('menu-icon');
	const closeIcon = document.getElementById('close-icon');
	const mobileNavLinks = document.querySelectorAll('.mobile-nav-link');

	function toggleMenu() {
		const isExpanded = mobileMenu?.classList.contains('hidden') === false;

		if (isExpanded) {
			mobileMenu?.classList.add('hidden');
			menuIcon?.classList.remove('hidden');
			closeIcon?.classList.add('hidden');
		} else {
			mobileMenu?.classList.remove('hidden');
			menuIcon?.classList.add('hidden');
			closeIcon?.classList.remove('hidden');
		}
	}

	menuToggle?.addEventListener('click', toggleMenu);

	// Close mobile menu when clicking a link
	mobileNavLinks.forEach(link => {
		link.addEventListener('click', () => {
			mobileMenu?.classList.add('hidden');
			menuIcon?.classList.remove('hidden');
			closeIcon?.classList.add('hidden');
		});
	});
</script>
