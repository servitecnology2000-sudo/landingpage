---
interface Props {
	href?: string;
	variant?: 'primary' | 'secondary' | 'outline';
	class?: string;
	[x: string]: any;
}

const { 
	href, 
	variant = 'primary', 
	class: className = '', 
	...rest 
} = Astro.props;

const baseStyles = "inline-flex items-center justify-center px-6 py-3 rounded-lg font-semibold text-sm transition-all duration-300 transform active:scale-95 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-offset-dark-bg cursor-pointer";

const variants = {
	primary: "bg-brand-cyan text-black hover:bg-brand-cyan/90 hover:shadow-[0_0_15px_rgba(0,207,255,0.5)] focus:ring-brand-cyan",
	secondary: "bg-brand-green text-black hover:bg-brand-green/90 hover:shadow-[0_0_15px_rgba(0,255,127,0.5)] focus:ring-brand-green",
	outline: "border border-brand-cyan/30 text-brand-cyan hover:bg-brand-cyan/10 hover:border-brand-cyan focus:ring-brand-cyan",
};

const classes = `${baseStyles} ${variants[variant]} ${className}`;
---

{
	href ? (
		<a href={href} class={classes} {...rest}>
			<slot />
		</a>
	) : (
		<button class={classes} {...rest}>
			<slot />
		</button>
	)
}
