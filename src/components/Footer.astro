---
const currentYear = new Date().getFullYear();

const quickLinks = [
	{ label: 'Inicio', href: '#' },
	{ label: 'Servicios', href: '#servicios' },
	{ label: 'Catálogo', href: '#catalogo' },
	{ label: 'Contacto', href: '#contacto' },
];

const coverageAreas = [
	"Santiago Centro", "Providencia", "Las Condes", "Ñuñoa", 
	"La Florida", "Maipú", "Puente Alto", "Peñalolén"
];
---

<footer id="contacto" class="relative bg-zinc-950 border-t border-white/5 pt-20 pb-8 overflow-hidden">
	<!-- Background glow -->
	<div class="absolute bottom-0 left-1/4 w-[400px] h-[400px] bg-brand-cyan/5 rounded-full blur-[160px] pointer-events-none"></div>

	<div class="relative z-10 mx-auto max-w-7xl px-6 w-full">
		<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12 lg:gap-8 mb-16">

			<!-- Column 1: Brand -->
			<div class="space-y-5">
				<a href="/" class="inline-block">
					<span class="text-2xl font-extrabold tracking-wider bg-gradient-to-r from-brand-green to-brand-cyan bg-clip-text text-transparent">
						SERVITECH
					</span>
				</a>
				<p class="text-sm text-slate-400 leading-relaxed">
					Soluciones informáticas profesionales, consultoría de sistemas y soporte IT de confianza. Tu aliado tecnológico en Santiago.
				</p>
				<!-- Social Links -->
				<div class="flex items-center gap-3 pt-2">
					<a href="#" aria-label="Instagram" class="flex items-center justify-center w-9 h-9 rounded-lg bg-white/5 border border-white/5 text-slate-400 hover:text-brand-cyan hover:border-brand-cyan/30 transition-all duration-300">
						<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C16.67.014 16.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
					</a>
					<a href="#" aria-label="Facebook" class="flex items-center justify-center w-9 h-9 rounded-lg bg-white/5 border border-white/5 text-slate-400 hover:text-brand-cyan hover:border-brand-cyan/30 transition-all duration-300">
						<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
					</a>
					<a href="#" aria-label="WhatsApp" class="flex items-center justify-center w-9 h-9 rounded-lg bg-white/5 border border-white/5 text-slate-400 hover:text-brand-green hover:border-brand-green/30 transition-all duration-300">
						<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.746.953 3.71 1.458 5.704 1.459h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
					</a>
				</div>
			</div>

			<!-- Column 2: Quick Links -->
			<div class="space-y-5">
				<h4 class="text-sm font-bold text-white uppercase tracking-wider">Enlaces Rápidos</h4>
				<nav class="flex flex-col gap-3">
					{quickLinks.map((link) => (
						<a href={link.href} class="text-sm text-slate-400 hover:text-brand-cyan transition-colors duration-300 w-fit">
							{link.label}
						</a>
					))}
				</nav>
			</div>

			<!-- Column 3: Schedule -->
			<div class="space-y-5">
				<h4 class="text-sm font-bold text-white uppercase tracking-wider">Horarios de Atención</h4>
				<div class="space-y-4">
					<div class="p-3 rounded-lg bg-white/5 border border-white/5 space-y-1">
						<div class="flex items-center gap-2">
							<svg class="w-4 h-4 text-brand-cyan shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
							</svg>
							<span class="text-xs font-semibold text-white">Lunes a Viernes</span>
						</div>
						<p class="text-xs text-slate-400 pl-6">Soporte Remoto Post-Oficina</p>
						<span class="text-xs font-bold text-brand-cyan pl-6">18:30 - 22:00 hrs</span>
					</div>
					<div class="p-3 rounded-lg bg-white/5 border border-white/5 space-y-1">
						<div class="flex items-center gap-2">
							<svg class="w-4 h-4 text-brand-green shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
							</svg>
							<span class="text-xs font-semibold text-white">Sábados y Domingos</span>
						</div>
						<p class="text-xs text-slate-400 pl-6">Soporte Presencial (En Terreno)</p>
						<span class="text-xs font-bold text-brand-green pl-6">Sujeto a Agendamiento</span>
					</div>
				</div>
			</div>

			<!-- Column 4: Coverage -->
			<div class="space-y-5">
				<h4 class="text-sm font-bold text-white uppercase tracking-wider">Cobertura Técnica</h4>
				<div class="flex flex-wrap gap-2">
					{coverageAreas.map((area) => (
						<span class="text-xs text-slate-400 px-2.5 py-1 rounded-full border border-white/5 bg-white/5">
							{area}
						</span>
					))}
				</div>
				<p class="text-xs text-slate-500 leading-relaxed pt-1">
					Atendemos la Región Metropolitana de Santiago de Chile. Consulta por cobertura especial fuera de estas áreas.
				</p>
			</div>
		</div>

		<!-- Bottom Bar -->
		<div class="border-t border-white/5 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-center sm:text-left">
			<p class="text-xs text-slate-500">
				© {currentYear} <span class="text-slate-400 font-semibold">SERVITECH</span>. Todos los derechos reservados.
			</p>
			<p class="text-xs text-slate-600">
				Diseñado y desarrollado con 💻 en Chile
			</p>
		</div>
	</div>
</footer>
