---
import { supabase } from '../lib/supabase';
import Button from './Button.astro';

// Fetch products from Supabase (with graceful error handling)
let items: any[] = [];
let dbError: string | null = null;

try {
	const { data: products, error } = await supabase
		.from('repuestos_productos')
		.select('*')
		.order('created_at', { ascending: false });
	
	if (error) {
		console.error('[Catalog] Supabase error:', error.message);
		dbError = error.message;
	} else {
		items = products ?? [];
	}
} catch (e: any) {
	console.error('[Catalog] Unexpected error:', e?.message);
	dbError = e?.message ?? 'Error de conexión';
}

// Derive categories dynamically from products
const uniqueCategories = [...new Set(items.map((p: any) => p.categoria).filter(Boolean))];
const categories = [
	{ id: "todos", label: "Todos" },
	...uniqueCategories.map(cat => ({ id: cat, label: cat }))
];

const phone = "56948672300";
---

<section id="catalogo" class="relative py-24 bg-black overflow-hidden border-t border-white/5">
	<!-- Background glows -->
	<div class="absolute top-0 left-1/3 w-[500px] h-[500px] bg-brand-green/5 rounded-full blur-[160px] pointer-events-none"></div>
	<div class="absolute bottom-0 right-1/4 w-[400px] h-[400px] bg-brand-cyan/5 rounded-full blur-[140px] pointer-events-none"></div>

	<div class="relative z-10 mx-auto max-w-7xl px-6 w-full">
		<!-- Section Header -->
		<div class="text-center max-w-3xl mx-auto mb-12 space-y-4">
			<div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-brand-cyan/20 bg-brand-cyan/5 text-brand-cyan text-xs font-semibold uppercase tracking-wider">
				Repuestos y Componentes
			</div>
			<h2 class="text-3xl md:text-5xl font-extrabold tracking-tight text-white">
				Repuestos y Componentes <br class="hidden sm:inline" />
				<span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-green to-brand-cyan">
					con Stock Garantizado
				</span>
			</h2>
			<p class="text-slate-400 text-base md:text-lg">
				Repuestos originales usados, testeados meticulosamente con stock garantizado y opción de instalación. Pantallas, teclados, almacenamiento y RAM para laptops y PCs de escritorio en Santiago.
			</p>
		</div>

		<!-- Filter Buttons -->
		{categories.length > 1 && (
			<div class="flex flex-wrap items-center justify-center gap-3 mb-12">
				{categories.map((cat) => (
					<button
						data-filter={cat.id}
						class:list={[
							"catalog-filter px-5 py-2.5 rounded-full text-sm font-semibold tracking-wide transition-all duration-300 cursor-pointer border",
							cat.id === "todos"
								? "bg-brand-cyan text-black border-brand-cyan shadow-[0_0_15px_rgba(0,207,255,0.3)]"
								: "bg-white/5 text-slate-400 border-white/10 hover:text-white hover:border-brand-cyan/30 hover:bg-white/10"
						]}
					>
						{cat.label}
					</button>
				))}
			</div>
		)}

		<!-- Products Grid -->
		{items.length === 0 ? (
			<div class="text-center py-20 space-y-4">
				<div class="text-6xl">📦</div>
				<p class="text-slate-400 text-lg">No hay productos en el catálogo aún.</p>
				<p class="text-slate-500 text-sm">Los productos se agregarán desde el panel de administración.</p>
			</div>
		) : (
			<div id="catalog-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
				{items.map((product) => {
					const msg = encodeURIComponent(`Hola SERVITECH, me interesa el repuesto: ${product.titulo} (SKU: ${product.sku}) que vi en su catálogo web. ¿Tienen disponibilidad?`);
					const waLink = `https://wa.me/${phone}?text=${msg}`;
					const images: string[] = product.imagenes ?? [];
					const hasMultipleImages = images.length > 1;
					const cardId = `card-${product.id}`;

					return (
						<div
							data-category={product.categoria}
							class="catalog-card group flex flex-col justify-between p-6 rounded-2xl border border-white/5 bg-zinc-950/50 backdrop-blur-sm transition-all duration-300 hover:border-brand-green/25 hover:-translate-y-1 hover:shadow-[0_0_25px_rgba(0,255,127,0.04)] overflow-hidden"
						>
							<div>
								{/* Image gallery / carousel */}
								{images.length > 0 && (
									<div class="relative w-full aspect-[4/3] rounded-xl overflow-hidden mb-4 bg-zinc-900 group/gallery">
										{images.map((img, idx) => (
											<img
												src={img}
												alt={`${product.titulo} - imagen ${idx + 1}`}
												class:list={[
													"carousel-img absolute inset-0 w-full h-full object-cover transition-opacity duration-500 cursor-zoom-in",
													idx === 0 ? "opacity-100 z-10" : "opacity-0"
												]}
												data-index={idx}
												data-lightbox-images={JSON.stringify(images)}
												loading="lazy"
											/>
										))}
										{hasMultipleImages && (
											<>
												<button
													type="button"
													class="carousel-prev absolute left-2 top-1/2 -translate-y-1/2 w-8 h-8 flex items-center justify-center rounded-full bg-black/40 text-white hover:bg-brand-cyan hover:text-black transition-all opacity-0 group-hover/gallery:opacity-100 z-20 focus:outline-none"
													aria-label="Anterior"
												>
													<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
												</button>
												<button
													type="button"
													class="carousel-next absolute right-2 top-1/2 -translate-y-1/2 w-8 h-8 flex items-center justify-center rounded-full bg-black/40 text-white hover:bg-brand-cyan hover:text-black transition-all opacity-0 group-hover/gallery:opacity-100 z-20 focus:outline-none"
													aria-label="Siguiente"
												>
													<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
												</button>
											</>
										)}
									</div>
								)}

								{/* Type badge + Category */}
								<div class="flex items-center justify-between gap-2 mb-3">
									<span class="text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full border text-brand-cyan bg-brand-cyan/10 border-brand-cyan/20">
										{product.estado || 'Usado Verificado'}
									</span>
									<span class="text-[10px] text-slate-500 uppercase tracking-wider font-medium">
										{product.categoria}
									</span>
								</div>

								{/* Title */}
								<h3 class="text-sm font-bold text-white leading-snug mb-2 min-h-[2.5rem] group-hover:text-brand-green transition-colors duration-300">
									<a href={`/repuesto/${product.slug}`} class="hover:underline">
										{product.titulo}
									</a>
								</h3>

								{/* Description */}
								{product.descripcion && (
									<p class="text-xs text-slate-400 leading-relaxed mb-3 line-clamp-2">
										{product.descripcion}
									</p>
								)}

								{/* Compatibility */}
								{product.compatibilidad && product.compatibilidad.length > 0 && (
									<div class="flex flex-wrap gap-1 mb-3">
										{product.compatibilidad.slice(0, 3).map((comp: string) => (
											<span class="text-[9px] px-1.5 py-0.5 rounded bg-white/5 text-slate-500 border border-white/5">
												{comp}
											</span>
										))}
									</div>
								)}

								{/* Stock badge */}
								<div class="flex items-center gap-2 mb-4">
									{product.stock_cantidad > 0 ? (
										<>
											<span class="w-2 h-2 rounded-full bg-brand-green animate-pulse shrink-0"></span>
											<span class="text-xs font-semibold text-brand-green">Disponibles: {product.stock_cantidad} unidades</span>
										</>
									) : (
										<>
											<span class="w-2 h-2 rounded-full bg-red-500 shrink-0"></span>
											<span class="text-xs font-semibold text-red-500">Agotado</span>
										</>
									)}
								</div>

								{/* Price */}
								<div class="flex items-baseline gap-1.5 mb-6">
									<span class="text-2xl font-extrabold text-white tracking-tight">
										${product.precio_venta?.toLocaleString('es-CL') ?? '---'}
									</span>
									<span class="text-[10px] text-slate-500 uppercase font-semibold">CLP</span>
								</div>
							</div>

							{/* CTA */}
							<div class="flex gap-2">
								<a
									href={product.stock_cantidad > 0 ? waLink : "#"}
									target={product.stock_cantidad > 0 ? "_blank" : "_self"}
									rel="noopener noreferrer"
									data-track-event="clic_boton"
									data-element-id={`btn_whatsapp_producto_${product.sku}`}
									class={`flex-1 flex items-center justify-center gap-1.5 px-3 py-2.5 rounded-lg text-[11px] font-semibold tracking-wide transition-all duration-300 ${product.stock_cantidad > 0 ? 'bg-brand-green/10 border border-brand-green/20 text-brand-green hover:bg-brand-green hover:text-black active:scale-95' : 'bg-red-500/10 border border-red-500/20 text-red-500/50 cursor-not-allowed pointer-events-none'}`}
								>
									<svg class="w-3.5 h-3.5 fill-current" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.746.953 3.71 1.458 5.704 1.459h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
									Consultar
								</a>
								<a
									href={`/repuesto/${product.slug}`}
									class="flex-1 flex items-center justify-center gap-1 px-3 py-2.5 rounded-lg bg-white/5 border border-white/10 text-slate-300 text-[11px] font-semibold tracking-wide hover:border-brand-cyan/30 hover:text-brand-cyan transition-all duration-300 active:scale-95"
								>
									Detalles
								</a>
							</div>
						</div>
					);
				})}
			</div>
		)}
	</div>
</section>

<script>
	// Category filter logic
	const filterButtons = document.querySelectorAll('.catalog-filter');
	const cards = document.querySelectorAll('.catalog-card');

	function setActiveFilter(activeBtn: Element) {
		filterButtons.forEach(btn => {
			btn.classList.remove('bg-brand-cyan', 'text-black', 'border-brand-cyan', 'shadow-[0_0_15px_rgba(0,207,255,0.3)]');
			btn.classList.add('bg-white/5', 'text-slate-400', 'border-white/10');
		});
		activeBtn.classList.remove('bg-white/5', 'text-slate-400', 'border-white/10');
		activeBtn.classList.add('bg-brand-cyan', 'text-black', 'border-brand-cyan', 'shadow-[0_0_15px_rgba(0,207,255,0.3)]');
	}

	filterButtons.forEach(btn => {
		btn.addEventListener('click', () => {
			const filter = btn.getAttribute('data-filter');
			setActiveFilter(btn);
			cards.forEach(card => {
				const category = card.getAttribute('data-category');
				const el = card as HTMLElement;
				if (filter === 'todos' || category === filter) {
					el.style.display = '';
					el.style.opacity = '0';
					el.style.transform = 'translateY(8px)';
					requestAnimationFrame(() => {
						el.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
						el.style.opacity = '1';
						el.style.transform = 'translateY(0)';
					});
				} else {
					el.style.display = 'none';
				}
			});
		});
	});

	// Image carousel arrows logic
	document.querySelectorAll('.catalog-card').forEach(card => {
		const prevBtn = card.querySelector('.carousel-prev') as HTMLButtonElement;
		const nextBtn = card.querySelector('.carousel-next') as HTMLButtonElement;
		const imgs = card.querySelectorAll('.carousel-img');
		if (!prevBtn || !nextBtn || imgs.length <= 1) return;
		
		let currentIndex = 0;
		const showImg = (idx: number) => {
			imgs.forEach((img, i) => {
				if (i === idx) {
					img.classList.replace('opacity-0', 'opacity-100');
					img.classList.add('z-10');
				} else {
					img.classList.replace('opacity-100', 'opacity-0');
					img.classList.remove('z-10');
				}
			});
			currentIndex = idx;
		};

		prevBtn.addEventListener('click', (e) => {
			e.stopPropagation();
			showImg((currentIndex - 1 + imgs.length) % imgs.length);
		});
		nextBtn.addEventListener('click', (e) => {
			e.stopPropagation();
			showImg((currentIndex + 1) % imgs.length);
		});
	});

	// Lightbox trigger logic
	document.querySelectorAll('.carousel-img').forEach(img => {
		img.addEventListener('click', () => {
			const imagesRaw = img.getAttribute('data-lightbox-images');
			if (!imagesRaw) return;
			try {
				const images = JSON.parse(imagesRaw);
				const idx = parseInt(img.getAttribute('data-index') || '0', 10);
				if ((window as any).openLightbox) {
					(window as any).openLightbox(images, idx);
				}
			} catch(e) {}
		});
	});
</script>
