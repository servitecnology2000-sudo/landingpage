---
import Button from './Button.astro';
---

<section class="relative min-h-[90vh] flex items-center justify-center overflow-hidden py-20 bg-black">
	<!-- Background Image with scroll fade-out effect -->
	<div id="hero-bg-image" class="absolute inset-0 z-0 pointer-events-none transition-opacity duration-75">
		<div class="absolute inset-0 bg-black/65 z-10"></div> <!-- Dark overlay to protect contrast -->
		<div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-black/20 z-10"></div> <!-- Top/bottom gradients -->
		<img src="/imagenes/principal.jpg" alt="SERVITECH Soporte Principal" class="w-full h-full object-cover object-center" />
	</div>

	<!-- Decorative background glows -->
	<div class="absolute top-1/4 left-1/4 -translate-x-1/2 -translate-y-1/2 w-[350px] md:w-[500px] h-[350px] md:h-[500px] bg-brand-cyan/10 rounded-full blur-[120px] pointer-events-none z-10"></div>
	<div class="absolute bottom-1/4 right-1/4 translate-x-1/2 translate-y-1/2 w-[350px] md:w-[500px] h-[350px] md:h-[500px] bg-brand-green/10 rounded-full blur-[120px] pointer-events-none z-10"></div>

	<!-- Background grid pattern -->
	<div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,rgba(255,255,255,0.02)_1px,transparent_1px)] bg-[size:32px_32px] pointer-events-none z-10"></div>

	<div class="relative z-20 mx-auto max-w-7xl px-6 w-full grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center">
		<!-- Text Content (7 columns on desktop) -->
		<div class="lg:col-span-7 space-y-8 text-left">
			<div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-brand-cyan/20 bg-brand-cyan/5 text-brand-cyan text-xs font-semibold uppercase tracking-wider">
				<span class="w-2 h-2 rounded-full bg-brand-cyan animate-pulse"></span>
				Soporte Técnico de Confianza
			</div>

			<h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-[4.75rem] xl:text-[5.5rem] font-black tracking-tight leading-[1.0] text-white drop-shadow-[0_4px_16px_rgba(0,0,0,0.8)]">
				Soporte Técnico Experto y 
				<span class="block mt-2 text-transparent bg-clip-text bg-gradient-to-r from-brand-cyan via-brand-cyan to-brand-green drop-shadow-[0_2px_10px_rgba(0,207,255,0.4)]">
					Soluciones Tecnológicas
				</span>
			</h1>

			<p class="text-lg text-slate-200 max-w-xl drop-shadow-[0_2px_4px_rgba(0,0,0,0.8)]">
				Optimizamos y reparamos tu infraestructura informática. Soluciones eficientes y soporte garantizado adaptado a tus necesidades y tiempos.
			</p>

			<!-- CTAs -->
			<div class="flex flex-wrap gap-4 pt-2">
				<Button data-track-event="clic_boton" data-element-id="btn_hero_soporte" variant="primary" href="#contacto" class="px-8 py-4 text-base shadow-[0_0_20px_rgba(0,207,255,0.25)] hover:shadow-[0_0_25px_rgba(0,207,255,0.45)]">
					Solicitar Soporte
				</Button>
				<Button data-track-event="clic_boton" data-element-id="btn_hero_servicios" variant="outline" href="#servicios" class="px-8 py-4 text-base bg-black/40 backdrop-blur-sm border-white/20 hover:bg-white/10">
					Explorar Servicios
				</Button>
				<Button data-track-event="clic_boton" data-element-id="btn_hero_catalogo" variant="outline" href="#catalogo" class="px-8 py-4 text-base bg-black/40 backdrop-blur-sm border-white/20 hover:bg-white/10">
					Repuestos y Componentes
				</Button>
				<Button data-track-event="clic_boton" data-element-id="btn_hero_escribenos" variant="primary" href="https://wa.me/56948672300?text=Hola%20SERVITECH,%20requiero%20soporte%20t%C3%A9cnico..." target="_blank" rel="noopener noreferrer" class="px-8 py-4 text-base shadow-[0_0_20px_rgba(0,255,127,0.25)] hover:shadow-[0_0_25px_rgba(0,255,127,0.45)] bg-brand-green/10 border-brand-green/30 text-brand-green hover:bg-brand-green hover:text-black flex items-center gap-2">
					<svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.746.953 3.71 1.458 5.704 1.459h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
					Escríbenos
				</Button>
			</div>
		</div>

		<!-- Schedule & Value Card (5 columns on desktop) -->
		<div class="lg:col-span-5 relative w-full">
			<!-- Glow border card container -->
			<div class="relative group">
				<!-- Background glow to highlight the card -->
				<div class="absolute -inset-0.5 bg-gradient-to-r from-brand-cyan to-brand-green rounded-2xl blur opacity-30 group-hover:opacity-40 transition duration-500"></div>
				
				<!-- Actual glass card -->
				<div class="relative flex flex-col justify-between p-6 sm:p-8 rounded-2xl border border-white/15 bg-zinc-950/85 backdrop-blur-2xl shadow-[0_25px_50px_-12px_rgba(0,0,0,0.8)]">
					<div class="relative z-10 space-y-6">
						<h3 class="text-xl font-bold text-white tracking-wide border-b border-white/5 pb-4 leading-snug">
							Soporte Técnico Fuera de Oficina: <br />
							<span class="text-brand-cyan">Trabajamos Mientras Tú Descansas</span>
						</h3>

						<p class="text-sm text-slate-300 leading-relaxed">
							Sabemos que tu jornada laboral no puede detenerse. Adaptamos nuestro soporte informático a tus horarios libres para asegurar tu continuidad operativa sin interrumpir tus actividades diarias.
						</p>

						<!-- Hours List -->
						<div class="space-y-4 pt-2">
							<!-- Weekdays -->
							<div class="flex items-start gap-3 p-3 rounded-lg bg-white/5 border border-white/5 hover:border-brand-cyan/20 transition-colors">
								<div class="p-2 rounded bg-brand-cyan/10 text-brand-cyan">
									<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
									</svg>
								</div>
								<div>
									<h4 class="text-sm font-semibold text-white">Lunes a Viernes</h4>
									<p class="text-xs text-slate-300 mt-1 leading-relaxed">
										Soporte Remoto After Office <strong class="text-brand-cyan font-bold">(18:30 - 22:00 hrs)</strong>. Soluciones inmediatas en línea sin moverte de casa.
									</p>
								</div>
							</div>

							<!-- Weekends -->
							<div class="flex items-start gap-3 p-3 rounded-lg bg-white/5 border border-white/5 hover:border-brand-green/20 transition-colors">
								<div class="p-2 rounded bg-brand-green/10 text-brand-green">
									<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
										<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
									</svg>
								</div>
								<div>
									<h4 class="text-sm font-semibold text-white">Sábados y Domingos</h4>
									<p class="text-xs text-slate-300 mt-1 leading-relaxed">
										Soporte Presencial en Terreno <strong class="text-brand-green font-bold">(Sujeto a Agendamiento)</strong>. Visitas a domicilio u oficina en toda la RM para hardware, cableado y CCTV.
									</p>
								</div>
							</div>
						</div>
					</div>

					<div class="relative z-10 mt-6 pt-4 border-t border-white/5 text-center">
						<span class="text-sm text-brand-green font-bold tracking-wide drop-shadow-[0_1px_6px_rgba(0,255,127,0.3)]">✓ Soporte certificado y con cobertura local</span>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<script>
	const bgImage = document.getElementById('hero-bg-image');
	if (bgImage) {
		window.addEventListener('scroll', () => {
			const scrollY = window.scrollY;
			const opacity = Math.max(0, 1 - scrollY / 600);
			bgImage.style.opacity = opacity.toString();
		}, { passive: true });
	}
</script>
